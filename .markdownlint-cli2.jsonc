{
  // Project-wide markdownlint configuration.
  //
  // Mirrors pd-ocr-synth — its spec/docs style is closest to this repo's
  // (long-form `specs/00-09` design docs with tables, fenced code, and
  // prose paragraphs that wrap at sentence boundaries).
  "config": {
    "default": true,
    "MD013": {
      "line_length": 120,
      "code_blocks": false,
      "tables": false,
      "headings": false,
      "strict": false
    },
    "MD022": false,
    "MD031": false,
    "MD040": false,
    "MD060": false
  },
  "ignores": [
    ".venv/**",
    "node_modules/**",
    "frontend/node_modules/**",
    "frontend/dist/**",
    "src/pd_prep_for_pgdp/static/**",
    ".pytest_cache/**",
    // Historical context — superseded by specs/00-09. Per CLAUDE.md
    // these are canonical and the proposal is reference-only.
    "specs/REFACTOR-PROPOSAL.md"
  ]
}
